# RapidAPI key — used for both Zillow and Apartments.com endpoints
# Sign up at https://rapidapi.com and subscribe to the APIs listed in README
RAPIDAPI_KEY=your_rapidapi_key_here

# Google Maps Distance Matrix API key
# Enable at https://console.cloud.google.com/apis/library/distance-matrix-backend.googleapis.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: GitHub Personal Access Token (for manual refresh button to trigger Actions)
GITHUB_PAT=your_github_pat_here
